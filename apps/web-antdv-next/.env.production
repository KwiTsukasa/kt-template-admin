VITE_BASE=/

# 接口地址
VITE_GLOB_API_URL=/api

# Admin 博客文章预览 iframe 目标，生产环境指向已部署 KT Blog Web
VITE_KT_BLOG_WEB_BASE_URL=https://blog.kwitsukasa.top/

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=none

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成dist.zip
VITE_ARCHIVER=true
